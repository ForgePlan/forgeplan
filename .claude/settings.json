{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/skill-activation-hook.sh"
          },
          {
            "type": "command",
            "command": "forgeplan health --compact --json 2>/dev/null || true",
            "timeout": 5,
            "statusMessage": "Checking project health..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/forge-safety-hook.sh",
            "timeout": 3,
            "statusMessage": "Safety check..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pr-todo-check.sh",
            "timeout": 5,
            "statusMessage": "Checking TODO checkboxes..."
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "javascript-typescript@claude-code-workflows": true,
    "backend-development@claude-code-workflows": true,
    "code-review-ai@claude-code-workflows": true,
    "tdd-workflows@claude-code-workflows": true,
    "full-stack-orchestration@claude-code-workflows": true,
    "git-pr-workflows@claude-code-workflows": true,
    "playwright-skill@playwright-skill": true
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  }
}
