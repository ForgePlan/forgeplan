---
// Hero section with crystallization animation + split bottom
import CrystallizationAnimation from './CrystallizationAnimation.tsx';
---

<section id="hero" class="relative flex flex-col border-b border-forge-line overflow-hidden">
  <!-- Crystallization Animation (React island with GSAP) -->
  <CrystallizationAnimation client:load />

  <!-- Bottom split -->
  <div class="border-t border-forge-line grid grid-cols-1 md:grid-cols-[1fr_480px] min-h-[220px]">
    <!-- Left: heading -->
    <div class="flex items-end p-6 md:p-8 border-r border-forge-line">
      <h1 class="font-heading text-4xl md:text-[58px] font-normal leading-[1.15]">
        From Raw Idea<br/>
        To Proven Decision <span class="text-forge-ember" aria-hidden="true">&gt;&gt;&gt;</span>
      </h1>
    </div>

    <!-- Right: description -->
    <div class="flex flex-col justify-between p-6 md:p-8">
      <p class="text-sm leading-relaxed text-forge-fg">
        Forgeplan turns unstructured thinking into structured artifacts you can trust, test, and ship — with quality scoring, evidence tracking, and semantic search built in.
      </p>
      <p class="text-sm font-bold text-forge-ember mt-4">
        Shape. Validate. Reason. Build. Prove.
      </p>
      <a href="/getting-started/installation" class="text-lg md:text-xl mt-4 text-forge-fg hover:text-forge-ember transition-colors">
        Get started <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>
