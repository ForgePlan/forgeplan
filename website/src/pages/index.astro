---
import Landing from '../layouts/Landing.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Install from '../components/Install.astro';

// React islands for sticky sections
import TrustSection from '../components/TrustSection.tsx';
import PipelineSection from '../components/PipelineSection.tsx';
---

<Landing>
  <Header />
  <main id="main-content">
    <!-- Hero: pinned 200% scroll, crystallization animation -->
    <Hero />

    <!-- Trust: pinned, scoring rings animate -->
    <TrustSection client:visible />

    <!-- Pipeline: pinned, depth routing + ADI reveal -->
    <PipelineSection client:visible />

    <!-- Install: no pin, just shows -->
    <Install />
  </main>
</Landing>
