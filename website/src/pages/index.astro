---
import Landing from '../layouts/Landing.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Install from '../components/Install.astro';

import TrustSection from '../components/TrustSection.tsx';
import PipelineSection from '../components/PipelineSection.tsx';
import ArtifactsSection from '../components/ArtifactsSection.tsx';
import GraphSection from '../components/GraphSection.tsx';
import AISection from '../components/AISection.tsx';
---

<Landing>
  <Header />
  <main id="main-content">
    <!-- 1. Hero: chaos → crystallization → "F●rge your plan" -->
    <Hero />

    <!-- 2. Trust: R_eff scoring rings + story cards -->
    <TrustSection client:visible />

    <!-- 3. Pipeline: SHAPE→PROVE timeline + git branching tree -->
    <PipelineSection client:visible />

    <!-- 4. Artifacts: 10 types interactive grid + preview -->
    <ArtifactsSection client:visible />

    <!-- 5. Graph: dependency DAG + blind spots -->
    <GraphSection client:visible />

    <!-- 6. AI: 72 MCP tools + terminal demo -->
    <AISection client:visible />

    <!-- 7. Install: cargo/brew/curl + footer -->
    <Install />
  </main>
</Landing>
