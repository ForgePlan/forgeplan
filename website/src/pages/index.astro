---
import Landing from '../layouts/Landing.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Install from '../components/Install.astro';
import TrustSection from '../components/TrustSection.tsx';
import PipelineSection from '../components/PipelineSection.tsx';
---

<Landing>
  <Header />
  <main id="main-content">
    <!-- Hero: ONLY pinned section (ScrollTrigger pin, 3x scroll) -->
    <Hero />

    <!-- Trust: scroll-driven (no pin, IntersectionObserver) -->
    <TrustSection client:visible />

    <!-- Pipeline: scroll-driven (no pin, IntersectionObserver) -->
    <PipelineSection client:visible />

    <!-- Install: static -->
    <Install />
  </main>
</Landing>
